{
  "name": "ashward",
  "version": "0.0.1",
  "description": "Test-support library that verifies a server's HTTP parser conforms to international standards (framing / request-smuggling resistance) from inside your test runner.",
  "keywords": [
    "bun",
    "conformance",
    "framing",
    "http",
    "request-smuggling",
    "rfc9112",
    "security",
    "testing",
    "typescript"
  ],
  "homepage": "https://github.com/zipbul/ashward#readme",
  "bugs": {
    "url": "https://github.com/zipbul/ashward/issues"
  },
  "license": "MIT",
  "author": "Junhyung Park (https://github.com/parkrevil)",
  "repository": {
    "type": "git",
    "url": "https://github.com/zipbul/ashward"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "changeset": "changeset",
    "coverage": "bun test --coverage",
    "format": "oxfmt --config .oxfmtrc.jsonc --check",
    "lint": "oxlint --config .oxlintrc.jsonc --type-aware",
    "prepare": "husky",
    "test": "bun test",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/bun": "latest",
    "@typescript/native-preview": "7.0.0-dev.20260629.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
