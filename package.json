{
  "name": "ashward",
  "version": "0.0.1",
  "description": "Test-support library that verifies a server's HTTP parser conforms to international standards (framing / request-smuggling resistance) from inside your test runner.",
  "license": "MIT",
  "author": "Junhyung Park (https://github.com/parkrevil)",
  "repository": {
    "type": "git",
    "url": "https://github.com/zipbul/ashward"
  },
  "bugs": {
    "url": "https://github.com/zipbul/ashward/issues"
  },
  "homepage": "https://github.com/zipbul/ashward#readme",
  "keywords": [
    "http",
    "conformance",
    "framing",
    "request-smuggling",
    "security",
    "testing",
    "bun",
    "rfc9112",
    "typescript"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "provenance": true
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "test": "bun test",
    "coverage": "bun test --coverage",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript/native-preview": "7.0.0-dev.20260629.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
