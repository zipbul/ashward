{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "allowJs": false,
    "emitDeclarationOnly": false,
    "declaration": true,
    "stripInternal": true,
    "noEmitOnError": true,
    "allowImportingTsExtensions": false,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["index.ts", "src"],
  "exclude": ["**/*.spec.ts", "**/*.test.ts", "**/test/**", "src/testkit/**", "**/dist/**"]
}
